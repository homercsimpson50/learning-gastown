# Gas Town Gateway — Secrets File
# Copy to ~/.gt-secrets/<project>.env and fill in real values.
# MUST be chmod 600.
#
# Each rig/project should have its own secrets file with
# minimally-scoped tokens.

# GitHub — fine-grained PAT scoped to specific repos only
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=github_pat_REPLACE_ME

# Jira — API token (user-scoped)
# Create at: https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_TOKEN=REPLACE_ME
JIRA_EMAIL=you@company.com
JIRA_URL=https://yourcompany.atlassian.net

# Slack — bot token scoped to specific channels
# Create at: https://api.slack.com/apps
SLACK_TOKEN=xoxb-REPLACE_ME
