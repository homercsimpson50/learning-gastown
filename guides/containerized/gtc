#!/usr/bin/env bash
#
# gtc — Gas Town Container CLI
#
# A wrapper around docker compose for the containerized Gas Town setup.
# Manages dynamic volume mounts for standalone repos and monorepo projects.
#
# Usage:
#   gtc up [options]          Start containers with repo/project mounts
#   gtc down                  Stop and remove containers
#   gtc status                Show container status
#   gtc attach                Attach to the Mayor session
#   gtc feed [args]           Run gt feed (pass any gt feed flags)
#   gtc exec <cmd>            Run a command inside the gastown container
#   gtc shell                 Open a shell inside the gastown container
#   gtc sync                  Sync fork with upstream gastown
#   gtc test                  Run integration tests
#
# Mount options (for 'gtc up'):
#   --repo <path>             Mount a standalone repo (repeatable)
#   --monorepo <path>         Set the monorepo root (e.g. ~/code/cpe-analytics)
#   -p, --project <number>    Mount a project from the monorepo (repeatable)
#                             Matches projects/<number>-* directories
#
# Examples:
#   gtc up --repo ~/code/frontend --repo ~/code/backend
#   gtc up --monorepo ~/code/cpe-analytics -p 42 -p 56
#   gtc up --repo ~/code/frontend --monorepo ~/code/cpe-analytics -p 42
#   gtc feed
#   gtc feed --agents
#   gtc attach

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
OVERRIDE_FILE="$SCRIPT_DIR/docker-compose.override.yml"

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[0;33m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
    GREEN=''; RED=''; YELLOW=''; BOLD=''; DIM=''; NC=''
fi

die() { echo -e "${RED}Error:${NC} $1" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Generate docker-compose.override.yml with volume mounts
# ---------------------------------------------------------------------------
generate_override() {
    local repos=("$@")

    if [ ${#repos[@]} -eq 0 ]; then
        # No mounts — remove override if it exists
        rm -f "$OVERRIDE_FILE"
        return
    fi

    cat > "$OVERRIDE_FILE" <<'HEADER'
# Auto-generated by gtc — do not edit manually.
# Re-run 'gtc up' with mount options to regenerate.
services:
  gastown:
    volumes:
HEADER

    for entry in "${repos[@]}"; do
        local host_path="${entry%%:*}"
        local container_path="${entry##*:}"
        echo "      - ${host_path}:${container_path}" >> "$OVERRIDE_FILE"
    done

    # Avoid VLogs port conflict if local VLogs is running on 9428
    if curl -sf http://localhost:9428/health >/dev/null 2>&1; then
        echo -e "  ${YELLOW}Note:${NC} Local VictoriaLogs detected on :9428, using :9429 for container"
        cat >> "$OVERRIDE_FILE" <<'EOF'

  victoria-logs:
    ports:
      - "9429:9428"
EOF
    fi
}

# ---------------------------------------------------------------------------
# Resolve monorepo project directories
# Populates the global RESOLVED_MOUNTS array
# ---------------------------------------------------------------------------
RESOLVED_MOUNTS=()

resolve_projects() {
    local monorepo="$1"
    shift
    local project_numbers=("$@")
    RESOLVED_MOUNTS=()

    local projects_dir="$monorepo/projects"
    if [ ! -d "$projects_dir" ]; then
        die "projects/ directory not found in monorepo: $projects_dir"
    fi

    for num in "${project_numbers[@]}"; do
        # Find directories matching <number>-*
        local matches=()
        while IFS= read -r -d '' dir; do
            matches+=("$dir")
        done < <(find "$projects_dir" -maxdepth 1 -type d -name "${num}-*" -print0 2>/dev/null)

        if [ ${#matches[@]} -eq 0 ]; then
            die "No project matching '${num}-*' found in $projects_dir"
        elif [ ${#matches[@]} -gt 1 ]; then
            echo -e "${RED}Warning:${NC} Multiple matches for project ${num}:" >&2
            for m in "${matches[@]}"; do
                echo "  $(basename "$m")" >&2
            done
            die "Ambiguous project number. Use a more specific number."
        fi

        local project_dir="${matches[0]}"
        local project_name="$(basename "$project_dir")"
        RESOLVED_MOUNTS+=("${project_dir}:/gt/rigs/${project_name}/repo")
        echo -e "  ${GREEN}+${NC} project ${BOLD}${project_name}${NC} → /gt/rigs/${project_name}/repo"
    done
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_up() {
    local repos=()
    local monorepo=""
    local project_numbers=()
    local mounts=()

    # Parse args
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo)
                [ -n "${2:-}" ] || die "--repo requires a path"
                local rpath="$(cd "$2" 2>/dev/null && pwd)" || die "repo path not found: $2"
                local rname="$(basename "$rpath")"
                repos+=("${rpath}:/gt/rigs/${rname}/repo")
                echo -e "  ${GREEN}+${NC} repo ${BOLD}${rname}${NC} → /gt/rigs/${rname}/repo"
                shift 2
                ;;
            --monorepo)
                [ -n "${2:-}" ] || die "--monorepo requires a path"
                monorepo="$(cd "$2" 2>/dev/null && pwd)" || die "monorepo path not found: $2"
                shift 2
                ;;
            -p|--project)
                [ -n "${2:-}" ] || die "-p/--project requires a project number"
                project_numbers+=("$2")
                shift 2
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done

    # Validate: -p requires --monorepo
    if [ ${#project_numbers[@]} -gt 0 ] && [ -z "$monorepo" ]; then
        die "-p/--project requires --monorepo <path>"
    fi

    # Resolve project directories
    if [ ${#project_numbers[@]} -gt 0 ]; then
        resolve_projects "$monorepo" "${project_numbers[@]}"
        mounts+=("${RESOLVED_MOUNTS[@]}")
    fi

    # Add standalone repos from CLI
    if [ ${#repos[@]} -gt 0 ]; then
        mounts+=("${repos[@]}")
    fi

    # Add mounts from config file (GTC_MOUNTS in ~/.gtc.conf)
    for path in ${GTC_MOUNTS:-}; do
        local name="$(basename "$path")"
        # Skip if already added via CLI
        local already=false
        for m in "${mounts[@]+"${mounts[@]}"}"; do
            if echo "$m" | grep -q "^${path}:"; then
                already=true
                break
            fi
        done
        if [ "$already" = false ] && [ -d "$path" ]; then
            mounts+=("${path}:/gt/rigs/${name}/repo")
            echo -e "  ${GREEN}+${NC} config ${BOLD}${name}${NC} → /gt/rigs/${name}/repo"
        fi
    done

    echo ""
    generate_override "${mounts[@]+"${mounts[@]}"}"

    # Export config vars so docker-compose.yml picks them up
    [ -n "${GITHUB_ALLOWED_REPOS:-}" ] && export GITHUB_ALLOWED_REPOS
    [ -n "${JIRA_ALLOWED_PROJECTS:-}" ] && export JIRA_ALLOWED_PROJECTS
    [ -n "${SECRETS_FILE:-}" ] && export SECRETS_FILE
    [ -n "${GTC_CODE_DIR:-}" ] && export GTC_CODE_DIR

    # Build compose command
    local compose_args=("-f" "$COMPOSE_FILE")
    if [ -f "$OVERRIDE_FILE" ]; then
        compose_args+=("-f" "$OVERRIDE_FILE")
    fi

    echo -e "${BOLD}Starting Gas Town containers...${NC}"
    docker compose "${compose_args[@]}" up -d

    echo ""
    echo -e "${GREEN}Containers running.${NC}"
    echo ""
    cmd_mounts
    echo ""
    echo -e "  gtc auth      — Set up GitHub/Jira auth"
    echo -e "  gtc attach    — Mayor session"
    echo -e "  gtc feed --agents  — Watch agent activity"
}

cmd_down() {
    # Block -v/--volumes to prevent accidental data loss (Claude auth, GT workspace, beads)
    for arg in "$@"; do
        case "$arg" in
            -v|--volumes)
                die "Refusing to delete volumes (would destroy Claude auth, GT workspace, beads data).
  To really delete everything: docker compose -f $COMPOSE_FILE down -v"
                ;;
        esac
    done

    local compose_args=("-f" "$COMPOSE_FILE")
    if [ -f "$OVERRIDE_FILE" ]; then
        compose_args+=("-f" "$OVERRIDE_FILE")
    fi
    docker compose "${compose_args[@]}" down "$@"
    echo -e "  ${GREEN}Volumes preserved.${NC} Data (auth, workspace, beads) persists for next gtc up."
}

cmd_status() {
    local compose_args=("-f" "$COMPOSE_FILE")
    if [ -f "$OVERRIDE_FILE" ]; then
        compose_args+=("-f" "$OVERRIDE_FILE")
    fi
    docker compose "${compose_args[@]}" ps

    echo ""
    echo -e "${BOLD}Mounted rigs:${NC}"
    if [ -f "$OVERRIDE_FILE" ] && grep -q '/gt/rigs/' "$OVERRIDE_FILE" 2>/dev/null; then
        grep '/gt/rigs/' "$OVERRIDE_FILE" | sed 's/.*- /  /' | while read -r line; do
            local host="${line%%:*}"
            local container="${line##*:}"
            local rig_name
            rig_name=$(echo "$container" | sed 's|/gt/rigs/||; s|/repo||')
            echo -e "  ${BOLD}${rig_name}${NC} ← ${host}"
        done
    else
        echo "  (none — run 'gtc up --repo <path>' to mount repos)"
    fi
}

cmd_attach() {
    docker compose -f "$COMPOSE_FILE" exec gastown gt mayor attach
}

OLLAMA_MODEL="${GTC_OLLAMA_MODEL:-qwen2.5:1.5b}"

_ensure_ollama() {
    # 1. Check if ollama is installed
    if ! command -v ollama >/dev/null 2>&1; then
        echo ""
        echo -e "${BOLD}AI Summary requires Ollama (local LLM runtime).${NC}"
        echo -e "  This will install Ollama via Homebrew and download the ${BOLD}${OLLAMA_MODEL}${NC} model (~1GB)."
        echo -e "  Estimated time: 2-5 minutes depending on internet speed."
        echo -e "  Ollama runs locally — ${GREEN}no cloud API calls, no cost.${NC}"
        echo ""
        read -r -p "  Install Ollama and download model? [Y/n] " confirm
        case "$confirm" in
            [nN]*) echo "  Skipping AI summary."; return 1 ;;
        esac
        echo ""
        echo -e "  ${BOLD}Installing Ollama...${NC}"
        brew install ollama || die "Failed to install Ollama"
    fi

    # 2. Check if ollama service is running
    if ! curl -sf http://localhost:11434/api/tags >/dev/null 2>&1; then
        echo -e "  Starting Ollama service..."
        brew services start ollama 2>/dev/null || ollama serve &>/dev/null &
        # Wait for it to be ready
        local tries=0
        while ! curl -sf http://localhost:11434/api/tags >/dev/null 2>&1; do
            tries=$((tries + 1))
            [ $tries -gt 15 ] && die "Ollama failed to start after 15 seconds"
            sleep 1
        done
        echo -e "  ${GREEN}Ollama running.${NC}"
    fi

    # 3. Check if model is pulled
    if ! ollama list 2>/dev/null | grep -q "$OLLAMA_MODEL"; then
        echo ""
        echo -e "  ${BOLD}Downloading model ${OLLAMA_MODEL}...${NC} (this is a one-time download)"
        ollama pull "$OLLAMA_MODEL" || die "Failed to download model"
        echo -e "  ${GREEN}Model ready.${NC}"
    fi

    return 0
}

cmd_feed() {
    # Detect container VLogs port
    local vlogs_port
    vlogs_port=$(docker inspect gt-victoria-logs --format '{{range $p,$conf := .NetworkSettings.Ports}}{{if eq $p "9428/tcp"}}{{(index $conf 0).HostPort}}{{end}}{{end}}' 2>/dev/null || echo "9428")

    # Check for --ai flag
    local ai_enabled=""
    local feed_args=()
    for arg in "$@"; do
        if [ "$arg" = "--ai" ]; then
            ai_enabled=1
        else
            feed_args+=("$arg")
        fi
    done

    # If --ai, ensure Ollama is set up
    if [ -n "$ai_enabled" ]; then
        if _ensure_ollama; then
            echo -e "  AI summary enabled. Press ${BOLD}s${NC} in the feed to toggle."
            echo ""
        else
            ai_enabled=""
        fi
    fi

    # Run local gt binary pointed at container VLogs
    GT_VLOGS_QUERY_URL="http://localhost:${vlogs_port}/select/logsql/query" \
    GT_OTEL_METRICS_URL= \
    GT_OTEL_LOGS_URL= \
    GT_FEED_AI="${ai_enabled}" \
    gt feed "${feed_args[@]}"

    # Cleanup: stop Ollama after feed exits to free memory
    if [ -n "$ai_enabled" ]; then
        echo -e "  Stopping Ollama to free memory..."
        brew services stop ollama 2>/dev/null || pkill -f ollama 2>/dev/null
    fi
}

cmd_exec() {
    docker compose -f "$COMPOSE_FILE" exec gastown "$@"
}

cmd_shell() {
    docker compose -f "$COMPOSE_FILE" exec gastown bash
}

cmd_test() {
    "$SCRIPT_DIR/test-container.sh"
}

# Config file for gtc settings
GTC_CONFIG="$HOME/.gtc.conf"
if [ -f "$GTC_CONFIG" ]; then
    # shellcheck source=/dev/null
    . "$GTC_CONFIG"
fi
# Mounts configured in ~/.gtc.conf as GTC_MOUNTS (space-separated paths)
# Example: GTC_MOUNTS="~/code/frontend ~/code/backend ~/code/monorepo"

cmd_mount() {
    local path="${1:-}"
    [ -n "$path" ] || die "Usage: gtc mount <path>"

    path="$(cd "$path" 2>/dev/null && pwd)" || die "Path not found: $1"
    local name="${2:-$(basename "$path")}"
    local code_dir="${GTC_CODE_DIR:-$HOME/code}"

    # Check if path is under the mounted code directory
    case "$path" in
        "$code_dir"/*)
            local rel="${path#$code_dir/}"
            echo -e "${GREEN}Available:${NC} $name → /gt/rigs-host/$rel"
            echo ""
            echo -e "  Tell the mayor: ${DIM}set up $name as a rig from /gt/rigs-host/$rel${NC}"
            ;;
        *)
            echo -e "${RED}Not under $code_dir${NC}"
            echo -e "  The container mounts ${BOLD}$code_dir${NC} → /gt/rigs-host/"
            echo -e "  Move the repo there, or set GTC_CODE_DIR in ~/.gtc.conf"
            ;;
    esac
}

cmd_unmount() {
    local current_mounts="${GTC_MOUNTS:-}"
    if [ -z "$current_mounts" ]; then
        echo "No mounts configured. (Check ~/.gtc.conf)"
        return
    fi

    # Direct name
    if [ -n "${1:-}" ]; then
        _remove_mount "$1"
        echo -e "Run ${BOLD}gtc up${NC} to apply."
        return
    fi

    # Build fzf list
    local mount_list=""
    for p in $current_mounts; do
        mount_list+="$(basename "$p") ($p)"$'\n'
    done
    mount_list=$(printf '%s' "$mount_list" | sed '/^$/d')

    local selected=""
    if command -v fzf >/dev/null 2>&1; then
        # Tab to toggle selection, Enter to confirm
        selected=$(echo "$mount_list" | fzf --multi \
            --header="Tab=toggle  Enter=confirm  Esc=cancel" \
            --prompt="unmount> " \
            --marker="✓ " --pointer="▸" \
            --height=40% --reverse \
            --border --border-label=" gtc unmount ") || true
        true  # fzf done
    else
        echo "$mount_list"
        echo ""
        read -r -p "Name to remove (or 'q' to cancel): " selected
        [ "$selected" = "q" ] && return
        # Treat as direct name
        _remove_mount "$selected"
        echo -e "Run ${BOLD}gtc up${NC} to apply."
        return
    fi

    if [ -z "$selected" ]; then
        echo "Cancelled."
        return
    fi

    # Process each selected line
    local removed=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        local rmpath
        rmpath=$(echo "$line" | sed 's/.*(\(.*\))/\1/')
        _remove_mount_by_path "$rmpath"
        removed=$((removed + 1))
    done <<< "$selected"

    if [ "$removed" -gt 0 ]; then
        echo ""
        echo -e "Removed $removed mount(s). Run ${BOLD}gtc up${NC} to apply."
    fi
}

_remove_mount() {
    local name="$1"
    local path
    for p in ${GTC_MOUNTS:-}; do
        if [ "$(basename "$p")" = "$name" ]; then
            path="$p"
            break
        fi
    done
    [ -z "${path:-}" ] && die "Mount not found: $name"
    _remove_mount_by_path "$path"
    _apply_mounts_and_restart
}

_remove_mount_by_path() {
    local path="$1"
    if [ -f "$GTC_CONFIG" ]; then
        # Remove path from GTC_MOUNTS in config
        local new_mounts
        new_mounts=$(echo "${GTC_MOUNTS:-}" | tr ' ' '\n' | grep -v "^${path}$" || true)
        new_mounts=$(echo "$new_mounts" | tr '\n' ' ' | sed 's/ $//')
        sed -i '' "s|^GTC_MOUNTS=.*|GTC_MOUNTS=\"$new_mounts\"|" "$GTC_CONFIG"
        # Re-source to update in-memory
        GTC_MOUNTS="$new_mounts"
    fi
    echo -e "${GREEN}Removed:${NC} $(basename "$path") ($path)"
}

_apply_mounts_and_restart() {
    # Regenerate override file from GTC_MOUNTS
    # Re-read config in case it changed
    [ -f "$GTC_CONFIG" ] && . "$GTC_CONFIG"

    local mounts="${GTC_MOUNTS:-}"
    if [ -z "$mounts" ]; then
        rm -f "$OVERRIDE_FILE"
    else
        cat > "$OVERRIDE_FILE" <<'HEADER'
# Auto-generated by gtc mount — do not edit manually.
services:
  gastown:
    volumes:
HEADER
        for path in $mounts; do
            local name="$(basename "$path")"
            echo "      - ${path}:/gt/rigs/${name}/repo" >> "$OVERRIDE_FILE"
        done
    fi

    # Soft-restart gastown only (volumes persist)
    local compose_args=("-f" "$COMPOSE_FILE")
    [ -f "$OVERRIDE_FILE" ] && compose_args+=("-f" "$OVERRIDE_FILE")
    docker compose "${compose_args[@]}" up -d --no-deps gastown 2>&1 | grep -v "^$"
}

cmd_mounts() {
    local code_dir="${GTC_CODE_DIR:-$HOME/code}"

    echo -e "${BOLD}Code directory:${NC} $code_dir → /gt/rigs-host/"
    echo ""
    echo -e "${BOLD}Available repos:${NC}"
    if [ -d "$code_dir" ]; then
        for dir in "$code_dir"/*/; do
            [ -d "$dir/.git" ] && echo -e "  ${GREEN}$(basename "$dir")${NC}"
        done
    else
        echo "  ($code_dir not found)"
    fi

    echo ""
    echo -e "  Tell the mayor to register a rig: ${DIM}set up <name> as a rig${NC}"
}

cmd_auth() {
    echo -e "${BOLD}Setting up auth for containerized GT...${NC}"

    # 1. Import gh token into gateway
    local gh_token
    gh_token=$(gh auth token 2>/dev/null) || die "gh not authenticated on host. Run: gh auth login"

    echo -e "  Importing GitHub token into gateway..."
    local result
    result=$(docker compose -f "$COMPOSE_FILE" exec -T gastown \
        curl -sf -X POST gateway:9999/tokens/import-gh \
        -H 'Content-Type: application/json' \
        -d "{\"token\":\"$gh_token\"}" 2>&1) || die "Gateway not reachable. Is the stack running?"

    local user
    user=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('user','?'))" 2>/dev/null)
    echo -e "  ${GREEN}GitHub:${NC} authenticated as ${BOLD}$user${NC}"

    # 2. Set up git credential helper in container (uses gateway)
    echo -e "  Configuring git credential helper..."
    docker compose -f "$COMPOSE_FILE" exec -T gastown bash -c '
        mkdir -p /home/agent/.local/bin
        cat > /home/agent/.local/bin/git-credential-gateway <<'\''CRED'\''
#!/bin/bash
if [[ "$1" == "get" ]]; then
    RESP=$(curl -s gateway:9999/git/credential 2>/dev/null)
    echo "protocol=$(echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin)[\"protocol\"])")"
    echo "host=$(echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin)[\"host\"])")"
    echo "username=$(echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin)[\"username\"])")"
    echo "password=$(echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin)[\"password\"])")"
fi
CRED
        chmod +x /home/agent/.local/bin/git-credential-gateway
        git config --global credential.helper /home/agent/.local/bin/git-credential-gateway
    ' 2>&1

    echo -e "  ${GREEN}Git:${NC} credential helper configured (tokens via gateway, never on disk)"

    # 3. Validate
    echo ""
    echo -e "  Validating tokens..."
    local validation
    validation=$(docker compose -f "$COMPOSE_FILE" exec -T gastown \
        curl -sf gateway:9999/tokens/validate 2>&1)
    echo "$validation" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for svc, info in d.items():
    status = '✓' if info.get('valid') else '✗'
    detail = info.get('user', info.get('error', ''))
    print(f'  {status} {svc}: {detail}')
" 2>/dev/null

    echo ""
    echo -e "${GREEN}Auth complete.${NC} Agents can now push to GitHub via the gateway."
}

cmd_sync() {
    echo -e "${BOLD}Syncing gastown fork with upstream...${NC}"

    local gastown_src="${GASTOWN_SRC:-$HOME/code/gastown-src}"
    if [ ! -d "$gastown_src" ]; then
        die "gastown-src not found at $gastown_src (set GASTOWN_SRC to override)"
    fi

    cd "$gastown_src"

    # Ensure remotes exist
    if ! git remote get-url origin &>/dev/null; then
        die "No 'origin' remote in $gastown_src"
    fi
    if ! git remote get-url fork &>/dev/null; then
        echo "Adding fork remote..."
        git remote add fork https://github.com/homercsimpson50/gastown.git
    fi

    # Update main from upstream
    echo "Fetching upstream (origin)..."
    git fetch origin main

    echo "Updating local main..."
    git checkout main
    git merge origin/main --ff-only

    # Rebase feature branch if it exists
    if git rev-parse --verify feat/agent-observability-tui &>/dev/null; then
        echo "Rebasing feat/agent-observability-tui onto main..."
        git checkout feat/agent-observability-tui
        git rebase main
        echo "Pushing to fork..."
        git push fork feat/agent-observability-tui --force-with-lease
        echo -e "${GREEN}Feature branch rebased and pushed.${NC}"
    fi

    # Switch back to main
    git checkout main

    echo ""
    echo -e "${GREEN}Sync complete.${NC} Rebuild image with:"
    echo -e "  ${DIM}cd $gastown_src && make build && make install${NC}"
    echo -e "  ${DIM}docker build -t gastown:latest -f Dockerfile .${NC}"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
cmd="${1:-help}"
shift || true

case "$cmd" in
    up)       cmd_up "$@" ;;
    down)     cmd_down "$@" ;;
    status)   cmd_status ;;
    attach)   cmd_attach ;;
    feed)     cmd_feed "$@" ;;
    mount)    cmd_mount "$@" ;;
    unmount)  cmd_unmount "$@" ;;
    mounts)   cmd_mounts ;;
    exec)     cmd_exec "$@" ;;
    shell)    cmd_shell ;;
    auth)     cmd_auth ;;
    test)     cmd_test ;;
    sync)     cmd_sync ;;
    help|-h|--help)
        echo "gtc — Gas Town Container CLI"
        echo ""
        echo "Usage:"
        echo "  gtc up [--repo <path>] [--monorepo <path> -p <num>]"
        echo "  gtc down"
        echo "  gtc status"
        echo "  gtc auth            Set up GitHub/Jira auth via gateway"
        echo "  gtc attach          Attach to Mayor (Ctrl-B D to detach)"
        echo "  gtc feed [flags]    Run gt feed (e.g. gtc feed --agents)"
        echo "  gtc exec <cmd>      Run command in container"
        echo "  gtc shell           Open bash in container"
        echo "  gtc sync            Sync fork with upstream gastown"
        echo "  gtc test            Run integration tests"
        echo ""
        echo "Repo mounts:"
        echo "  gtc mount ~/code/myproject       Add mount (saves to config + restarts)"
        echo "  gtc unmount                      Interactive remove (fzf)"
        echo "  gtc unmount myproject             Direct remove"
        echo "  gtc mounts                       List configured mounts"
        echo ""
        echo "Config: ~/.gtc.conf"
        echo "  GTC_MOUNTS=\"~/code/repo1 ~/code/repo2\"  (loaded on gtc up)"
        ;;
    *)
        die "Unknown command: $cmd (try 'gtc help')"
        ;;
esac
