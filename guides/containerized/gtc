#!/usr/bin/env bash
#
# gtc — Gas Town Container CLI
#
# A wrapper around docker compose for the containerized Gas Town setup.
# Manages dynamic volume mounts for standalone repos and monorepo projects.
#
# Usage:
#   gtc up [options]          Start containers with repo/project mounts
#   gtc down                  Stop and remove containers
#   gtc status                Show container status
#   gtc attach                Attach to the Mayor session
#   gtc feed [args]           Run gt feed (pass any gt feed flags)
#   gtc exec <cmd>            Run a command inside the gastown container
#   gtc shell                 Open a shell inside the gastown container
#   gtc sync                  Sync fork with upstream gastown
#   gtc test                  Run integration tests
#
# Mount options (for 'gtc up'):
#   --repo <path>             Mount a standalone repo (repeatable)
#   --monorepo <path>         Set the monorepo root (e.g. ~/code/cpe-analytics)
#   -p, --project <number>    Mount a project from the monorepo (repeatable)
#                             Matches projects/<number>-* directories
#
# Examples:
#   gtc up --repo ~/code/frontend --repo ~/code/backend
#   gtc up --monorepo ~/code/cpe-analytics -p 42 -p 56
#   gtc up --repo ~/code/frontend --monorepo ~/code/cpe-analytics -p 42
#   gtc feed
#   gtc feed --agents
#   gtc attach

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
OVERRIDE_FILE="$SCRIPT_DIR/docker-compose.override.yml"

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[0;33m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
    GREEN=''; RED=''; YELLOW=''; BOLD=''; DIM=''; NC=''
fi

die() { echo -e "${RED}Error:${NC} $1" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Generate docker-compose.override.yml with volume mounts
# ---------------------------------------------------------------------------
generate_override() {
    local repos=("$@")

    if [ ${#repos[@]} -eq 0 ]; then
        # No mounts — remove override if it exists
        rm -f "$OVERRIDE_FILE"
        return
    fi

    cat > "$OVERRIDE_FILE" <<'HEADER'
# Auto-generated by gtc — do not edit manually.
# Re-run 'gtc up' with mount options to regenerate.
services:
  gastown:
    volumes:
HEADER

    for entry in "${repos[@]}"; do
        local host_path="${entry%%:*}"
        local container_path="${entry##*:}"
        echo "      - ${host_path}:${container_path}" >> "$OVERRIDE_FILE"
    done

    # Avoid VLogs port conflict if local VLogs is running on 9428
    if curl -sf http://localhost:9428/health >/dev/null 2>&1; then
        echo -e "  ${YELLOW}Note:${NC} Local VictoriaLogs detected on :9428, using :9429 for container"
        cat >> "$OVERRIDE_FILE" <<'EOF'

  victoria-logs:
    ports:
      - "9429:9428"
EOF
    fi
}

# ---------------------------------------------------------------------------
# Resolve monorepo project directories
# Populates the global RESOLVED_MOUNTS array
# ---------------------------------------------------------------------------
RESOLVED_MOUNTS=()

resolve_projects() {
    local monorepo="$1"
    shift
    local project_numbers=("$@")
    RESOLVED_MOUNTS=()

    local projects_dir="$monorepo/projects"
    if [ ! -d "$projects_dir" ]; then
        die "projects/ directory not found in monorepo: $projects_dir"
    fi

    for num in "${project_numbers[@]}"; do
        # Find directories matching <number>-*
        local matches=()
        while IFS= read -r -d '' dir; do
            matches+=("$dir")
        done < <(find "$projects_dir" -maxdepth 1 -type d -name "${num}-*" -print0 2>/dev/null)

        if [ ${#matches[@]} -eq 0 ]; then
            die "No project matching '${num}-*' found in $projects_dir"
        elif [ ${#matches[@]} -gt 1 ]; then
            echo -e "${RED}Warning:${NC} Multiple matches for project ${num}:" >&2
            for m in "${matches[@]}"; do
                echo "  $(basename "$m")" >&2
            done
            die "Ambiguous project number. Use a more specific number."
        fi

        local project_dir="${matches[0]}"
        local project_name="$(basename "$project_dir")"
        RESOLVED_MOUNTS+=("${project_dir}:/gt/rigs/${project_name}/repo")
        echo -e "  ${GREEN}+${NC} project ${BOLD}${project_name}${NC} → /gt/rigs/${project_name}/repo"
    done
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_up() {
    local repos=()
    local monorepo=""
    local project_numbers=()
    local mounts=()

    # Parse args
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo)
                [ -n "${2:-}" ] || die "--repo requires a path"
                local rpath="$(cd "$2" 2>/dev/null && pwd)" || die "repo path not found: $2"
                local rname="$(basename "$rpath")"
                repos+=("${rpath}:/gt/rigs/${rname}/repo")
                echo -e "  ${GREEN}+${NC} repo ${BOLD}${rname}${NC} → /gt/rigs/${rname}/repo"
                shift 2
                ;;
            --monorepo)
                [ -n "${2:-}" ] || die "--monorepo requires a path"
                monorepo="$(cd "$2" 2>/dev/null && pwd)" || die "monorepo path not found: $2"
                shift 2
                ;;
            -p|--project)
                [ -n "${2:-}" ] || die "-p/--project requires a project number"
                project_numbers+=("$2")
                shift 2
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done

    # Validate: -p requires --monorepo
    if [ ${#project_numbers[@]} -gt 0 ] && [ -z "$monorepo" ]; then
        die "-p/--project requires --monorepo <path>"
    fi

    # Resolve project directories
    if [ ${#project_numbers[@]} -gt 0 ]; then
        resolve_projects "$monorepo" "${project_numbers[@]}"
        mounts+=("${RESOLVED_MOUNTS[@]}")
    fi

    # Add standalone repos
    if [ ${#repos[@]} -gt 0 ]; then
        mounts+=("${repos[@]}")
    fi

    echo ""
    generate_override "${mounts[@]+"${mounts[@]}"}"

    # Build compose command
    local compose_args=("-f" "$COMPOSE_FILE")
    if [ -f "$OVERRIDE_FILE" ]; then
        compose_args+=("-f" "$OVERRIDE_FILE")
    fi

    echo -e "${BOLD}Starting Gas Town containers...${NC}"
    docker compose "${compose_args[@]}" up -d

    echo ""
    echo -e "${GREEN}Containers running.${NC}"
    if [ ${#mounts[@]} -gt 0 ]; then
        echo ""
        echo "Next: add rigs inside the container:"
        echo -e "  ${DIM}gtc exec gt rig add <name> /gt/rigs/<name>/repo --adopt${NC}"
    fi
    echo ""
    echo -e "  gtc attach    — Mayor session"
    echo -e "  gtc feed      — Activity dashboard"
    echo -e "  gtc shell     — Container shell"
}

cmd_down() {
    local compose_args=("-f" "$COMPOSE_FILE")
    if [ -f "$OVERRIDE_FILE" ]; then
        compose_args+=("-f" "$OVERRIDE_FILE")
    fi
    docker compose "${compose_args[@]}" down "$@"
}

cmd_status() {
    local compose_args=("-f" "$COMPOSE_FILE")
    if [ -f "$OVERRIDE_FILE" ]; then
        compose_args+=("-f" "$OVERRIDE_FILE")
    fi
    docker compose "${compose_args[@]}" ps

    echo ""
    echo -e "${BOLD}Mounted rigs:${NC}"
    if [ -f "$OVERRIDE_FILE" ] && grep -q '/gt/rigs/' "$OVERRIDE_FILE" 2>/dev/null; then
        grep '/gt/rigs/' "$OVERRIDE_FILE" | sed 's/.*- /  /' | while read -r line; do
            local host="${line%%:*}"
            local container="${line##*:}"
            local rig_name
            rig_name=$(echo "$container" | sed 's|/gt/rigs/||; s|/repo||')
            echo -e "  ${BOLD}${rig_name}${NC} ← ${host}"
        done
    else
        echo "  (none — run 'gtc up --repo <path>' to mount repos)"
    fi
}

cmd_attach() {
    docker compose -f "$COMPOSE_FILE" exec gastown gt mayor attach
}

cmd_feed() {
    docker compose -f "$COMPOSE_FILE" exec -e GT_VLOGS_QUERY_URL=http://victoria-logs:9428/select/logsql/query gastown gt feed "$@"
}

cmd_exec() {
    docker compose -f "$COMPOSE_FILE" exec gastown "$@"
}

cmd_shell() {
    docker compose -f "$COMPOSE_FILE" exec gastown bash
}

cmd_test() {
    "$SCRIPT_DIR/test-container.sh"
}

# Config file for gtc settings
GTC_CONFIG="$HOME/.gtc.conf"
if [ -f "$GTC_CONFIG" ]; then
    # shellcheck source=/dev/null
    . "$GTC_CONFIG"
fi
MOUNTS_FILE="$SCRIPT_DIR/.gtc-mounts"

# Read current mounts from the mounts file (one "path:name" per line)
_read_mounts() {
    if [ -f "$MOUNTS_FILE" ]; then
        cat "$MOUNTS_FILE"
    fi
}

# Regenerate docker-compose.override.yml from mounts file and restart gastown
_apply_mounts() {
    local mounts=()
    while IFS= read -r line; do
        [ -n "$line" ] && mounts+=("$line")
    done < <(_read_mounts)

    if [ ${#mounts[@]} -eq 0 ]; then
        rm -f "$OVERRIDE_FILE"
    else
        cat > "$OVERRIDE_FILE" <<'HEADER'
# Auto-generated by gtc mount — do not edit manually.
services:
  gastown:
    volumes:
HEADER
        for entry in "${mounts[@]}"; do
            local host_path="${entry%%:*}"
            local name="${entry##*:}"
            echo "      - ${host_path}:/gt/rigs/${name}/repo" >> "$OVERRIDE_FILE"
        done
    fi

    # Detect local VLogs port conflict
    if curl -sf http://localhost:9428/health >/dev/null 2>&1; then
        # Check if it's our container or a local brew instance
        local container_vlogs
        container_vlogs=$(docker inspect gt-victoria-logs --format '{{range $p,$conf := .NetworkSettings.Ports}}{{if eq $p "9428/tcp"}}{{(index $conf 0).HostPort}}{{end}}{{end}}' 2>/dev/null || echo "")
        if [ "$container_vlogs" != "9428" ]; then
            echo -e "  ${YELLOW}Note:${NC} Local VictoriaLogs detected on :9428, using :9429 for container"
            cat >> "$OVERRIDE_FILE" <<'EOF'

  victoria-logs:
    ports:
      - "9429:9428"
EOF
        fi
    fi

    # Soft-restart: only recreates gastown, volumes persist
    local compose_args=("-f" "$COMPOSE_FILE")
    [ -f "$OVERRIDE_FILE" ] && compose_args+=("-f" "$OVERRIDE_FILE")
    docker compose "${compose_args[@]}" up -d --no-deps gastown 2>&1 | grep -v "^$"
}

cmd_mount() {
    local path="${1:-}"
    [ -n "$path" ] || die "Usage: gtc mount <path> [name]"

    path="$(cd "$path" 2>/dev/null && pwd)" || die "Path not found: $1"
    local name="${2:-$(basename "$path")}"

    # Check if already mounted
    if grep -q ":${name}$" "$MOUNTS_FILE" 2>/dev/null; then
        echo -e "${YELLOW}Already mounted:${NC} $name"
        return
    fi

    echo "${path}:${name}" >> "$MOUNTS_FILE"
    echo -e "${GREEN}Mounted:${NC} $name → $path"

    _apply_mounts
    echo -e "  Tell the mayor: ${DIM}set up $name as a rig${NC}"
}

cmd_unmount() {
    local name="${1:-}"
    [ -n "$name" ] || die "Usage: gtc unmount <name>"

    if ! grep -q ":${name}$" "$MOUNTS_FILE" 2>/dev/null; then
        die "Not mounted: $name"
    fi

    grep -v ":${name}$" "$MOUNTS_FILE" > "$MOUNTS_FILE.tmp" && mv "$MOUNTS_FILE.tmp" "$MOUNTS_FILE"
    echo -e "${GREEN}Unmounted:${NC} $name"

    _apply_mounts
}

cmd_mounts() {
    echo -e "${BOLD}Mounted rigs:${NC}"
    if [ -f "$MOUNTS_FILE" ] && [ -s "$MOUNTS_FILE" ]; then
        while IFS=: read -r path name; do
            echo -e "  ${GREEN}$name${NC} → $path"
        done < "$MOUNTS_FILE"
    else
        echo "  (none — run 'gtc mount ~/code/myproject')"
    fi
}

cmd_sync() {
    echo -e "${BOLD}Syncing gastown fork with upstream...${NC}"

    local gastown_src="${GASTOWN_SRC:-$HOME/code/gastown-src}"
    if [ ! -d "$gastown_src" ]; then
        die "gastown-src not found at $gastown_src (set GASTOWN_SRC to override)"
    fi

    cd "$gastown_src"

    # Ensure remotes exist
    if ! git remote get-url origin &>/dev/null; then
        die "No 'origin' remote in $gastown_src"
    fi
    if ! git remote get-url fork &>/dev/null; then
        echo "Adding fork remote..."
        git remote add fork https://github.com/homercsimpson50/gastown.git
    fi

    # Update main from upstream
    echo "Fetching upstream (origin)..."
    git fetch origin main

    echo "Updating local main..."
    git checkout main
    git merge origin/main --ff-only

    # Rebase feature branch if it exists
    if git rev-parse --verify feat/agent-observability-tui &>/dev/null; then
        echo "Rebasing feat/agent-observability-tui onto main..."
        git checkout feat/agent-observability-tui
        git rebase main
        echo "Pushing to fork..."
        git push fork feat/agent-observability-tui --force-with-lease
        echo -e "${GREEN}Feature branch rebased and pushed.${NC}"
    fi

    # Switch back to main
    git checkout main

    echo ""
    echo -e "${GREEN}Sync complete.${NC} Rebuild image with:"
    echo -e "  ${DIM}cd $gastown_src && make build && make install${NC}"
    echo -e "  ${DIM}docker build -t gastown:latest -f Dockerfile .${NC}"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
cmd="${1:-help}"
shift || true

case "$cmd" in
    up)       cmd_up "$@" ;;
    down)     cmd_down "$@" ;;
    status)   cmd_status ;;
    attach)   cmd_attach ;;
    feed)     cmd_feed "$@" ;;
    mount)    cmd_mount "$@" ;;
    unmount)  cmd_unmount "$@" ;;
    mounts)   cmd_mounts ;;
    exec)     cmd_exec "$@" ;;
    shell)    cmd_shell ;;
    test)     cmd_test ;;
    sync)     cmd_sync ;;
    help|-h|--help)
        echo "gtc — Gas Town Container CLI"
        echo ""
        echo "Usage:"
        echo "  gtc up [--repo <path>] [--monorepo <path> -p <num>]"
        echo "  gtc down"
        echo "  gtc status"
        echo "  gtc attach          Attach to Mayor (Ctrl-B D to detach)"
        echo "  gtc feed [flags]    Run gt feed (e.g. gtc feed --agents)"
        echo "  gtc exec <cmd>      Run command in container"
        echo "  gtc shell           Open bash in container"
        echo "  gtc sync            Sync fork with upstream gastown"
        echo "  gtc test            Run integration tests"
        echo ""
        echo "Hot-mount repos (no restart):"
        echo "  gtc mount ~/code/myproject      Mount a repo"
        echo "  gtc mount ~/code/myproject api   Mount with custom name"
        echo "  gtc unmount myproject            Remove a mount"
        echo "  gtc mounts                       List mounted repos"
        echo ""
        echo "Legacy mount (requires restart):"
        echo "  gtc up --repo ~/code/frontend --repo ~/code/backend"
        echo "  gtc up --monorepo ~/code/cpe-analytics -p 42 -p 56"
        ;;
    *)
        die "Unknown command: $cmd (try 'gtc help')"
        ;;
esac
